APP_NAME=security-scanner
DEBUG=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["*"]

DOCKER_SOCKET_PATH=/var/run/docker.sock

TRIVY_PATH=/usr/local/bin/trivy
COSIGN_PATH=/usr/local/bin/cosign
YARA_RULES_DIR=/rules
CLAMAV_DB_PATH=/var/lib/clamav

SCANNER_MAX_TIMEOUT=300
BLOCK_ON_HIGH_CVES=true
BLOCK_ON_MALWARE=true
BLOCK_ON_SECRETS=true
BLOCK_ON_ROOT_USER=true

COSIGN_KEY_PATH=/keys/cosign.key
COSIGN_KEY_PASSWORD=
COSIGN_KEYLESS=false
