# URLs des autres microservices (noms Docker Compose = noms DNS internes)
AUTH_SERVICE_URL=http://auth-service:8001
SCANNER_SERVICE_URL=http://security-scanner:8006
REGISTRY_SERVICE_URL=http://registry-service:8007

# Base de données PostgreSQL propre à ce service
DATABASE_URL=postgresql://minipaas:minipaas@postgres:5432/minipaas

# Dossier temporaire où les repos sont clonés pendant le build
BUILD_WORKDIR=/tmp/builds

# Timeout max d'un build en secondes (300 = 5 minutes)
MAX_BUILD_TIMEOUT=300

# Environnement : development ou production
ENV=development
