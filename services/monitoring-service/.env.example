# Base de données propre au monitoring-service
# En Docker Compose : monitor-db
# En local direct   : localhost
DATABASE_URL=postgresql://monitoruser:monitorpass@monitor-db:5432/monitordb

# Intervalle de collecte des métriques en secondes (défaut 30)
COLLECT_INTERVAL_SECONDS=30

# Rétention des métriques en jours (défaut 7)
METRICS_RETENTION_DAYS=7

# Nombre de lignes de logs retournées par défaut
LOG_TAIL_LINES=100

# Environnement : development ou production
ENV=development
