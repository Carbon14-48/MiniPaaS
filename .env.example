# Database
DATABASE_URL=postgresql://cloudoku:cloudoku@postgres:5432/cloudoku

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Docker Registry
DOCKER_REGISTRY_URL=localhost:5000

# Kubernetes
KUBECONFIG_PATH=/root/.kube/config

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Services URLs
AUTH_SERVICE_URL=http://auth-service:8001
APP_MANAGEMENT_SERVICE_URL=http://app-management:8002
BUILD_SERVICE_URL=http://build-service:8003
DEPLOYMENT_SERVICE_URL=http://deployment-service:8004
MONITORING_SERVICE_URL=http://monitoring-service:8005
SECURITY_SCANNER_URL=http://security-scanner:8006
DEPLOYER_SERVICE_URL=http://deployer-service:8008
REGISTRY_SERVICE_URL=http://registry-service:8007

# Message Broker
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Logging
LOG_LEVEL=INFO
